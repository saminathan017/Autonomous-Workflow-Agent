# ─────────────────────────────────────────────
# OpenAI Configuration (cost-efficient)
# Model: gpt-4o-mini — $0.15/1M input, $0.60/1M output
# ─────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_CALLS_PER_RUN=50
OPENAI_CONCURRENCY_LIMIT=5

# ─────────────────────────────────────────────
# Google OAuth Configuration
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8001/auth/callback

# ─────────────────────────────────────────────
# Google Sheets Configuration
# ─────────────────────────────────────────────
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ─────────────────────────────────────────────
# PostgreSQL Database
# Format: postgresql://user:password@host:port/dbname
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/workflow_agent
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─────────────────────────────────────────────
# Redis — multi-process WebSocket pub/sub
# Required when running multiple uvicorn workers
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────
# Security
# Set API_SECRET_KEY to enforce X-API-Key header on /api/* routes.
# Leave empty to disable auth (safe for local use only).
# ─────────────────────────────────────────────
API_SECRET_KEY=
ALLOWED_ORIGINS=http://localhost:8001,http://127.0.0.1:8001

# ─────────────────────────────────────────────
# Application Configuration
# ─────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8001
APP_DEBUG=false
LOG_LEVEL=INFO

# ─────────────────────────────────────────────
# Workflow Configuration
# ─────────────────────────────────────────────
WORKFLOW_MAX_RETRIES=3
WORKFLOW_RETRY_DELAY_SECONDS=2
